  createdBy           User                 @relation("createdBy", fields: [createdById], references: [id])
  createdById         Int
  updatedBy           User?                @relation("updatedBy", fields: [updatedById], references: [id])
  updatedById         Int?
  Store               Location             @relation(fields: [storeId], references: [id])
  storeId             Int
  Supplier            Party?               @relation(fields: [supplierId], references: [id])
  supplierId          Int?
  vehicleNo           String?
  specialInstructions String?
  remarks             String?
  userDeliveryDate    DateTime?
  Branch              Branch               @relation(fields: [branchId], references: [id])
  branchId            Int
  OnlineSalesDetails  OnlineSalesDetails[]
}

model OnlineSalesDetails {
  id                       Int                        @id @default(autoincrement())
  OnlineSales              OnlineSales                @relation(fields: [onlineSalesId], references: [id], onDelete: Cascade)
  onlineSalesId            Int
  Style                    Style                      @relation(fields: [styleId], references: [id])
  styleId                  Int
  Uom                      UnitOfMeasurement          @relation(fields: [uomId], references: [id])
  uomId                    Int
  Color                    Color                      @relation(fields: [colorId], references: [id])
  colorId                  Int
  Size                     Size                       @relation(fields: [sizeId], references: [id])
  sizeId                   Int
  PrevProcess              Process?                   @relation(fields: [prevProcessId], references: [id])
  prevProcessId            Int?
  qty                      Int
  StockForPcs              StockForPcs?
  OnlineSalesReturnDetails OnlineSalesReturnDetails[]
}

model OnlineSalesReturn {
  id                       Int                        @id @default(autoincrement())
  docId                    String
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
  createdBy                User                       @relation("createdBy", fields: [createdById], references: [id])
  createdById              Int
  updatedBy                User?                      @relation("updatedBy", fields: [updatedById], references: [id])
  updatedById              Int?
  Store                    Location                   @relation(fields: [storeId], references: [id])
  storeId                  Int
  Supplier                 Party?                     @relation(fields: [supplierId], references: [id])
  supplierId               Int?
  vehicleNo                String?
  specialInstructions      String?
  remarks                  String?
  userDeliveryDate         DateTime?
  Branch                   Branch                     @relation(fields: [branchId], references: [id])
  branchId                 Int
  OnlineSalesReturnDetails OnlineSalesReturnDetails[]
}

model OnlineSalesReturnDetails {
  id                   Int                @id @default(autoincrement())
  OnlineSalesReturn    OnlineSalesReturn  @relation(fields: [onlineSalesReturnId], references: [id], onDelete: Cascade)
  onlineSalesReturnId  Int
  OnlineSalesDetails   OnlineSalesDetails @relation(fields: [onlineSalesDetailsId], references: [id])
  onlineSalesDetailsId Int
  qty                  Int
  StockForPcs          StockForPcs?
}

enum Credit_Debit {
  Credit
  Debit
}

model CreditDebitNote {
  id            Int          @id @default(autoincrement())
  docId         String
  type          Credit_Debit
  TaxTemplate   TaxTemplate? @relation(fields: [taxTemplateId], references: [id])
  amount        Float?
  tax           Float?
  narration     String?      @db.LongText
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  createdBy     User         @relation("createdBy", fields: [createdById], references: [id])
  createdById   Int
  updatedBy     User?        @relation("updatedBy", fields: [updatedById], references: [id])
  updatedById   Int?
  Supplier      Party?       @relation(fields: [supplierId], references: [id])
  supplierId    Int?
  Branch        Branch       @relation(fields: [branchId], references: [id])
  branchId      Int
  Ledger        Ledger?
  taxTemplateId Int?
}

model Order {
  id               Int            @id @default(autoincrement())
  docId            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  createdBy        User?          @relation("createdBy", fields: [createdById], references: [id])
  createdById      Int?
  updatedBy        User?          @relation("updatedBy", fields: [updatedById], references: [id])
  updatedById      Int?
  phoneNo          String?
  customer         String?
  billingAddress   String?
  shippingAddress  String?
  orderDate        DateTime?
  deliveryDate     DateTime?
  gmail            String?
  Branch           Branch?        @relation(fields: [branchId], references: [id])
  branchId         Int?
  Party            Party?         @relation(fields: [partyId], references: [id], onDelete: Cascade)
  partyId          Int?
  packingCoverType String?
  orderDetails     OrderDetails[]
}

model OrderDetails {
  id                  Int                   @id @default(autoincrement())
  Order               Order?                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId             Int?
  orderDetailsSubGrid OrderDetailsSubGrid[]
}

model OrderDetailsSubGrid {
  id             Int           @id @default(autoincrement())
  OrderDetails   OrderDetails? @relation(fields: [orderDetailsId], references: [id], onDelete: Cascade)
  orderDetailsId Int?
}

model Machine {
