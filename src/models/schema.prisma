// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["clientExtensions"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Page {
  id          Int          @id @default(autoincrement())
  name        String
  link        String?
  type        PageType
  RoleOnPage  RoleOnPage[]
  active      Boolean      @default(true)
  PageGroup   PageGroup?   @relation(fields: [pageGroupId], references: [id])
  pageGroupId Int?
}

model Company {
  id                 Int                  @id @default(autoincrement())
  companyId          String               @unique @default(uuid())
  name               String
  code               String?
  gstNo              String?
  panNo              String?
  contactName        String?
  contactMobile      BigInt
  contactEmail       String?
  bankName           String?
  accNo              String?
  branchName         String?
  ifscCode           String?
  branch             Branch[]
  country            Country[]
  active             Boolean              @default(true)
  Department         Department[]
  Role               Role[]
  Subscription       Subscription[]
  finYear            FinYear[]
  PartyCategory      PartyCategory[]
  Currency           Currency[]
  Party              Party[]
  Content            Content[]
  Portion            Portion[]
  Counts             Counts[]
  YarnType           YarnType[]
  Hsn                Hsn[]
  YarnBlend          YarnBlend[]
  Yarn               Yarn[]
  FabricType         FabricType[]
  Fabric             Fabric[]
  AccessoryGroup     AccessoryGroup[]
  AccessoryItem      AccessoryItem[]
  Accessory          Accessory[]
  Color              Color[]
  UnitOfMeasurement  UnitOfMeasurement[]
  PayTerm            PayTerm[]
  TaxTerm            TaxTerm[]
  TaxTemplate        TaxTemplate[]
  Gauge              Gauge[]
  Design             Design[]
  LoopLength         LoopLength[]
  Gsm                Gsm[]
  Dia                Dia[]
  Size               Size[]
  Location           Location[]
  Process            Process[]
  SizeTemplate       SizeTemplate[]
  Style              Style[]
  TermsAndConditions TermsAndConditions[]
  LossReason         LossReason[]
  PriceTemplate      PriceTemplate[]
  SocksMaterial      SocksMaterial[]
  SocksType          SocksType[]
  Measurement        Measurement[]
  FiberContent       FiberContent[]
  Certificate        Certificate[]
  Order              Order[]
  Sample             Sample[]
  RaiseIndent        RaiseIndent[]
  MaterialIssue      MaterialIssue[]
}

model Subscription {
  id        Int      @id @default(autoincrement())
  Company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId Int
  validFrom DateTime
  expireAt  DateTime
  code      String
  maxUsers  Int
}

model Branch {
  id                                     Int                          @id @default(autoincrement())
  branchName                             String
  branchCode                             String?
  contactName                            String?
  contactMobile                          BigInt
  contactEmail                           String?
  company                                Company                      @relation(fields: [companyId], references: [id])
  companyId                              Int
  active                                 Boolean                      @default(true)
  EmployeeCategory                       EmployeeCategory[]
  UserOnBranch                           UserOnBranch[]
  Employee                               Employee[]
  idPrefix                               String?
  idSequence                             String?
  tempPrefix                             String?
  tempSequence                           String?
  prefixCategory                         PrefixCategory?
  address                                String?
  gstNo                                  String?
  panNo                                  String?
  DeliveryBranchPo                       Po[]                         @relation(name: "deliveryBranch")
  PoRaised                               Po[]                         @relation(name: "poRaisedBranch")
  PInwardOrReturn                        PInwardOrReturn[]
  Location                               Location[]
  Stock                                  Stock[]
  ProcessDelivery                        ProcessDelivery[]
  ProcessInward                          ProcessInward[]
  CuttingOrder                           CuttingOrder[]
  CuttingDelivery                        CuttingDelivery[]
  StockForPcs                            StockForPcs[]
  CuttingReceipt                         CuttingReceipt[]
  DirectInwardOrReturn                   DirectInwardOrReturn[]
  BillEntry                              BillEntry[]
  Payout                                 Payout[]
  AdvanceAdjustMent                      AdvanceAdjustMent[]
  ProcessDeliveryReturn                  ProcessDeliveryReturn[]
  CuttingExcessFabricReturn              CuttingExcessFabricReturn[]
  ProductionDelivery                     ProductionDelivery[]
  ProductionReceipt                      ProductionReceipt[]
  RawMaterialsSales                      RawMaterialsSales[]
  RawMaterialsSalesDetails               RawMaterialsSalesDetails[]
  FinishedGoodsSales                     FinishedGoodsSales[]
  RawMaterialOpeningStock                RawMaterialOpeningStock[]
  FinishedGoodsOpeningStock              FinishedGoodsOpeningStock[]
  FinishedGoodsSalesDelivery             FinishedGoodsSalesDelivery[]
  StockTransferFinishedGoodsDeliveryTo   StockTransferFinishedGoods[] @relation(name: "deliveryToBranch")
  StockTransferFinishedGoodsRaisedBranch StockTransferFinishedGoods[] @relation(name: "raisedBranch")
  PrintingJobWork                        PrintingJobWork[]            @relation(name: "raisedBranch")
  OnlineSales                            OnlineSales[]
  OnlineSalesReturn                      OnlineSalesReturn[]
  CreditDebitNote                        CreditDebitNote[]
  Order                                  Order[]
  Sample                                 Sample[]
  DirectReturnOrPoReturn                 DirectReturnOrPoReturn[]
  PurchaseCancel                         PurchaseCancel[]
  RequirementPlanningForm                RequirementPlanningForm[]
  RaiseIndent                            RaiseIndent[]
  MaterialIssue                          MaterialIssue[]
  DeliveryBranchAccessoryPo              AccessoryPo[]                @relation(name: "deliveryBranch")
  PoRaisedAccessoryPo                    AccessoryPo[]                @relation(name: "poRaisedBranch")
  AccesssoryPurchaseCancel               AccesssoryPurchaseCancel[]
  AccessoryInward                        AccessoryInward[]
  AccessoryReturn                        AccessoryReturn[]
  AccessoryBillEntry                     AccessoryBillEntry[]
  AccessoryStock                         AccessoryStock[]
}

model UserOnBranch {
  id       Int    @id @default(autoincrement())
  Branch   Branch @relation(fields: [branchId], references: [id])
  branchId Int
  User     User   @relation(fields: [userId], references: [id])
  userId   Int
}

model Role {
  id          Int          @id @default(autoincrement())
  name        String
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId   Int
  User        User[]
  RoleOnPage  RoleOnPage[]
  active      Boolean      @default(true)
  defaultRole Boolean      @default(false)

  @@unique([companyId, name])
}

model RoleOnPage {
  id     Int     @id @default(autoincrement())
  role   Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId Int
  page   Page    @relation(fields: [pageId], references: [id], onDelete: Cascade)
  pageId Int
  read   Boolean @default(false)
  create Boolean @default(false)
  edit   Boolean @default(false)
  delete Boolean @default(false)

  @@unique([roleId, pageId])
}

model User {
  id                                  Int                          @id @default(autoincrement())
  username                            String                       @unique
  email                               String?
  Employee                            Employee?                    @relation(fields: [employeeId], references: [id])
  password                            String
  role                                Role?                        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId                              Int?
  otp                                 String?
  active                              Boolean                      @default(true)
  UserOnBranch                        UserOnBranch[]
  employeeId                          Int?
  partyCreatedBy                      Party[]                      @relation(name: "createdBy")
  partyUpdatedBy                      Party[]                      @relation(name: "updatedBy")
  poCreatedBy                         Po[]                         @relation(name: "createdBy")
  poUpdatedBy                         Po[]                         @relation(name: "updatedBy")
  PInwardOrReturnCreatedBy            PInwardOrReturn[]            @relation(name: "createdBy")
  PInwardOrReturnUpdateBy             PInwardOrReturn[]            @relation(name: "updatedBy")
  ProcessDeliveryCreatedBy            ProcessDelivery[]            @relation(name: "createdBy")
  ProcessDeliveryUpdateBy             ProcessDelivery[]            @relation(name: "updatedBy")
  ProcessInwardCreatedBy              ProcessInward[]              @relation(name: "createdBy")
  ProcessInwardUpdateBy               ProcessInward[]              @relation(name: "updatedBy")
  TermsAndConditionsCreatedBy         TermsAndConditions[]         @relation(name: "createdBy")
  TermsAndConditionsUpdateBy          TermsAndConditions[]         @relation(name: "updatedBy")
  CuttingOrderCreatedBy               CuttingOrder[]               @relation(name: "createdBy")
  CuttingOrderUpdatedBy               CuttingOrder[]               @relation(name: "updatedBy")
  CuttingDeliveryCreatedBy            CuttingDelivery[]            @relation(name: "createdBy")
  CuttingDeliveryUpdatedBy            CuttingDelivery[]            @relation(name: "updatedBy")
  CuttingReceiptCreatedBy             CuttingReceipt[]             @relation(name: "createdBy")
  CuttingReceiptUpdatedBy             CuttingReceipt[]             @relation(name: "updatedBy")
  DirectInwardOrReturnCreatedBy       DirectInwardOrReturn[]       @relation(name: "createdBy")
  DirectInwardOrReturnUpdatedBy       DirectInwardOrReturn[]       @relation(name: "updatedBy")
  BillEntryCreatedBy                  BillEntry[]                  @relation(name: "createdBy")
  BillEntryUpdatedBy                  BillEntry[]                  @relation(name: "updatedBy")
  PayoutCreatedBy                     Payout[]                     @relation(name: "createdBy")
  PayoutUpdatedBy                     Payout[]                     @relation(name: "updatedBy")
  AdvanceAdjustMentCreatedBy          AdvanceAdjustMent[]          @relation(name: "createdBy")
  AdvanceAdjustMentUpdatedBy          AdvanceAdjustMent[]          @relation(name: "updatedBy")
  ProcessDeliveryReturnCreatedBy      ProcessDeliveryReturn[]      @relation(name: "createdBy")
  ProcessDeliveryReturnUpdatedBy      ProcessDeliveryReturn[]      @relation(name: "updatedBy")
  CuttingExcessFabricReturnCreatedBy  CuttingExcessFabricReturn[]  @relation(name: "createdBy")
  CuttingExcessFabricReturnUpdatedBy  CuttingExcessFabricReturn[]  @relation(name: "updatedBy")
  ProductionDeliveryCreatedBy         ProductionDelivery[]         @relation(name: "createdBy")
  ProductionDeliveryUpdatedBy         ProductionDelivery[]         @relation(name: "updatedBy")
  ProductionReceiptCreatedBy          ProductionReceipt[]          @relation(name: "createdBy")
  ProductionReceiptUpdatedBy          ProductionReceipt[]          @relation(name: "updatedBy")
  RawMaterialsSalesCreatedBy          RawMaterialsSales[]          @relation(name: "createdBy")
  RawMaterialsSalesUpdatedBy          RawMaterialsSales[]          @relation(name: "updatedBy")
  FinishedGoodsSalesCreatedBy         FinishedGoodsSales[]         @relation(name: "createdBy")
  FinishedGoodsSalesUpdatedBy         FinishedGoodsSales[]         @relation(name: "updatedBy")
  RawMaterialOpeningStockCreatedBy    RawMaterialOpeningStock[]    @relation(name: "createdBy")
  RawMaterialOpeningStockUpdatedBy    RawMaterialOpeningStock[]    @relation(name: "updatedBy")
  FinishedGoodsOpeningStockCreatedBy  FinishedGoodsOpeningStock[]  @relation(name: "createdBy")
  FinishedGoodsOpeningStockUpdatedBy  FinishedGoodsOpeningStock[]  @relation(name: "updatedBy")
  FinishedGoodsSalesDeliveryCreatedBy FinishedGoodsSalesDelivery[] @relation(name: "createdBy")
  FinishedGoodsSalesDeliveryUpdatedBy FinishedGoodsSalesDelivery[] @relation(name: "updatedBy")
  StockTransferFinishedGoodsCreatedBy StockTransferFinishedGoods[] @relation(name: "createdBy")
  StockTransferFinishedGoodsUpdatedBy StockTransferFinishedGoods[] @relation(name: "updatedBy")
  PrintingJobWorkCreatedBy            PrintingJobWork[]            @relation(name: "createdBy")
  PrintingJobWorkUpdatedBy            PrintingJobWork[]            @relation(name: "updatedBy")
  OnlineSalesCreatedBy                OnlineSales[]                @relation(name: "createdBy")
  OnlineSalesUpdatedBy                OnlineSales[]                @relation(name: "updatedBy")
  OnlineSalesReturnCreatedBy          OnlineSalesReturn[]          @relation(name: "createdBy")
  OnlineSalesReturnUpdatedBy          OnlineSalesReturn[]          @relation(name: "updatedBy")
  CreditDebitNoteCreatedBy            CreditDebitNote[]            @relation(name: "createdBy")
  CreditDebitNoteUpdatedBy            CreditDebitNote[]            @relation(name: "updatedBy")
  Order                               Order[]                      @relation(name: "createdBy")
  UpdatedOrder                        Order[]                      @relation(name: "updatedBy")
  SampleCreatedBy                     Sample[]                     @relation(name: "createdBy")
  SampleUpdatedBy                     Sample[]                     @relation(name: "updatedBy")
  Sample                              Sample[]
  DirectReturnOrPoReturnCreatedBy     DirectReturnOrPoReturn[]     @relation(name: "createdBy")
  DirectReturnOrPoReturnUpdatedBy     DirectReturnOrPoReturn[]     @relation(name: "updatedBy")
  PurchaseCancelCreatedBy             PurchaseCancel[]             @relation(name: "createdBy")
  PurchaseCancelUpdatedBy             PurchaseCancel[]             @relation(name: "updatedBy")
  RequirementPlanningCreatedBy        RequirementPlanningForm[]    @relation(name: "createdBy")
  RequirementPlanningUpdateBy         RequirementPlanningForm[]    @relation(name: "updatedBy")
  RaiseIndentCreatedBy                RaiseIndent[]                @relation(name: "createdBy")
  RaiseIndentUpdateBy                 RaiseIndent[]                @relation(name: "updatedBy")
  MaterialIssueCreatedBy              MaterialIssue[]              @relation(name: "createdBy")
  MaterialIssueUpdateBy               MaterialIssue[]              @relation(name: "updatedBy")
  StockTransferCreatedBy              StockTransfer[]              @relation(name: "createdBy")
  StockTransferUpdateBy               StockTransfer[]              @relation(name: "updatedBy")
  AccessoryPoCreatedBy                AccessoryPo[]                @relation(name: "createdBy")
  AccessoryPoUpdateBy                 AccessoryPo[]                @relation(name: "updatedBy")
  AccesssoryPurchaseCancelCreatedBy   AccesssoryPurchaseCancel[]   @relation(name: "createdBy")
  AccesssoryPurchaseCancelUpdateBy    AccesssoryPurchaseCancel[]   @relation(name: "updatedBy")
  AccessoryInwardCreatedBy            AccessoryInward[]            @relation(name: "createdBy")
  AccessoryInwardUpdateBy             AccessoryInward[]            @relation(name: "updatedBy")
  AccessoryReturnCreatedBy            AccessoryReturn[]            @relation(name: "createdBy")
  AccessoryReturnUpdateBy             AccessoryReturn[]            @relation(name: "updatedBy")
  AccessoryBillEntryCreatedBy         AccessoryBillEntry[]         @relation(name: "createdBy")
  AccessoryBillEntryUpdateBy          AccessoryBillEntry[]         @relation(name: "updatedBy")
  AccessoyStockTransferCreatedBy      AccessoyStockTransfer[]      @relation(name: "createdBy")
  AccessoyStockTransferUpdateBy       AccessoyStockTransfer[]      @relation(name: "updatedBy")
}

model Employee {
  id                 Int               @id @default(autoincrement())
  name               String?
  email              String?           @unique
  regNo              String?           @unique
  chamberNo          String?
  department         Department?       @relation(fields: [departmentId], references: [id])
  departmentId       Int?
  joiningDate        DateTime?
  fatherName         String?
  dob                DateTime?
  gender             Gender?
  maritalStatus      MaritalStatus?
  bloodGroup         BloodGroup?
  panNo              String?
  consultFee         String?
  salaryPerMonth     String?
  commissionCharges  String?
  mobile             BigInt?
  accountNo          String?
  ifscNo             String?
  branchName         String?
  degree             String?
  specialization     String?
  localAddress       String?
  localCity          City?             @relation("localCity", fields: [localCityId], references: [id])
  localCityId        Int?
  localPincode       Int?
  permAddress        String?
  permCity           City?             @relation("permCity", fields: [permCityId], references: [id])
  permCityId         Int?
  permPincode        Int?
  active             Boolean?          @default(true)
  image              Bytes?            @db.LongBlob
  Branch             Branch?           @relation(fields: [branchId], references: [id])
  branchId           Int?
  EmployeeCategory   EmployeeCategory? @relation(fields: [employeeCategoryId], references: [id])
  employeeCategoryId Int?
  permanent          Boolean?          @default(false)
  leavingReason      String?
  leavingDate        DateTime?
  canRejoin          Boolean?          @default(true)
  rejoinReason       String?
  createdAt          DateTime?         @default(now())
  updatedAt          DateTime?         @updatedAt
  User               User[]
}

model FinYear {
  id            Int             @id @default(autoincrement())
  from          DateTime
  to            DateTime
  Company       Company?        @relation(fields: [companyId], references: [id])
  companyId     Int?
  active        Boolean         @default(true)
  Order         Order[]
  RaiseIndent   RaiseIndent[]
  MaterialIssue MaterialIssue[]
}

model EmployeeCategory {
  id              Int        @id @default(autoincrement())
  name            String?
  code            String?
  Branch          Branch?    @relation(fields: [branchId], references: [id])
  branchId        Int?
  active          Boolean?   @default(true)
  defaultCategory Boolean?   @default(false)
  Employee        Employee[]
}

model Country {
  id        Int     @id @default(autoincrement())
  name      String
  code      String
  state     State[]
  active    Boolean @default(true)
  Company   Company @relation(fields: [companyId], references: [id])
  companyId Int
}

model Certificate {
  id                Int                 @id @default(autoincrement())
  name              String
  code              String
  active            Boolean             @default(true)
  Company           Company             @relation(fields: [companyId], references: [id])
  companyId         Int
  CertificateDetail CertificateDetail[]
}

model State {
  id        Int     @id @default(autoincrement())
  name      String
  code      String
  gstNo     String
  country   Country @relation(fields: [countryId], references: [id])
  countryId Int
  city      City[]
  active    Boolean @default(true)
}

model City {
  id              Int           @id @default(autoincrement())
  name            String
  code            String
  state           State         @relation(fields: [stateId], references: [id])
  stateId         Int
  active          Boolean       @default(true)
  doctorLocalCity Employee[]    @relation(name: "localCity")
  doctorPermCity  Employee[]    @relation(name: "permCity")
  Party           Party[]
  PartyBranch     PartyBranch[]
}

model Department {
  id        Int        @id @default(autoincrement())
  name      String
  code      String
  active    Boolean    @default(true)
  doctor    Employee[] @relation()
  Company   Company    @relation(fields: [companyId], references: [id])
  companyId Int
}

enum PageType {
  Masters
  Transactions
  Reports
  AdminAccess
}

model PageGroup {
  id     Int      @id @default(autoincrement())
  type   PageType
  name   String
  Page   Page[]
  active Boolean  @default(true)
}

enum PrefixCategory {
  Default
  Specific
}

enum BloodGroup {
  AP
  BP
  AN
  BN
  ABP
  ABN
  OP
  ON
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum MaritalStatus {
  SINGLE
  MARRIED
  SEPARATED
}

// PS TEX Tables
model PartyCategory {
  id        Int      @id @default(autoincrement())
  name      String
  code      String
  Company   Company? @relation(fields: [companyId], references: [id])
  companyId Int?
  active    Boolean  @default(true)
}

model Currency {
  id        Int      @id @default(autoincrement())
  name      String
  code      String?
  Company   Company? @relation(fields: [companyId], references: [id])
  companyId Int?
  active    Boolean  @default(true)
  Party     Party[]
}

model Party {
  id                  Int       @id @default(autoincrement())
  isSupplier          Boolean?  @default(false)
  isClient            Boolean?  @default(false)
  isBuyer             Boolean?  @default(false)
  name                String
  aliasName           String?
  code                String?
  active              Boolean?  @default(true)
  displayName         String?
  address             String?   @db.LongText
  landMark            String?
  City                City?     @relation(fields: [cityId], references: [id])
  cityId              Int?
  pincode             Int?
  email               String?
  contact             BigInt?
  contactPersonName   String?
  designation         String?
  department          String?
  contactPersonEmail  String?
  contactPersonNumber Int?
  alterContactNumber  Int?
  website             String?
  Currency            Currency? @relation(fields: [currencyId], references: [id])
  currencyId          Int?
  payTermDay          String?
  panNo               String?
  gstNo               String?
  msmeNo              String?
  cinNo               String?
  bankName            String?
  branchName          String?
  accountNumber       String?
  ifscCode            String?
  createdById         Int?

  image                 Bytes?                  @db.LongBlob
  tinNo                 String?
  cstNo                 String?
  cstDate               DateTime?               @db.Date
  faxNo                 String?
  costCode              String?
  PartyOnAccessoryItems PartyOnAccessoryItems[]
  Company               Company?                @relation(fields: [companyId], references: [id])
  companyId             Int?
  yarn                  Boolean?                @default(false)
  fabric                Boolean?                @default(false)
  accessoryGroup        Boolean?                @default(false)
  createdAt             DateTime?               @default(now())
  updatedAt             DateTime?               @updatedAt
  createdBy             User?                   @relation("createdBy", fields: [createdById], references: [id])
  updatedBy             User?                   @relation("updatedBy", fields: [updatedById], references: [id])
  updatedById           Int?
  PriceTemplate         PriceTemplate?          @relation(fields: [priceTemplateId], references: [id])
  priceTemplateId       Int?
  isIgst                Boolean?                @default(false)
  isAcc                 Boolean?                @default(false)
  isGy                  Boolean?                @default(false)
  isDy                  Boolean?                @default(false)
  mailId                String?

  PoSupplier                 Po[]                         @relation(name: "supplier")
  PoDelivery                 Po[]                         @relation(name: "deliveryTo")
  PInwardOrReturn            PInwardOrReturn[]
  PartyOnProcess             PartyOnProcess[]
  ProcessDelivery            ProcessDelivery[]
  CuttingOrder               CuttingOrder[]
  CuttingDeliverySupplier    CuttingDelivery[]            @relation(name: "supplier")
  CuttingDeliveryToParty     CuttingDelivery[]            @relation(name: "deliveryTo")
  CuttingReceiptSupplier     CuttingReceipt[]             @relation(name: "supplier")
  CuttingReceiptToParty      CuttingReceipt[]             @relation(name: "deliveryTo")
  DirectInwardOrReturn       DirectInwardOrReturn[]
  BillEntry                  BillEntry[]
  Ledger                     Ledger[]
  Payout                     Payout[]
  CuttingExcessFabricReturn  CuttingExcessFabricReturn[]
  ProductionDeliverySupplier ProductionDelivery[]         @relation(name: "supplier")
  ProductionDeliveryToParty  ProductionDelivery[]         @relation(name: "deliveryTo")
  ProductionReceiptSupplier  ProductionReceipt[]          @relation(name: "supplier")
  ProductionReceiptToParty   ProductionReceipt[]          @relation(name: "deliveryTo")
  RawMaterialsSalesSupplier  RawMaterialsSales[]          @relation(name: "supplier")
  RawMaterialsSalesToParty   RawMaterialsSales[]          @relation(name: "deliveryTo")
  FinishedGoodsSalesSupplier FinishedGoodsSales[]         @relation(name: "supplier")
  FinishedGoodsSalesDelivery FinishedGoodsSalesDelivery[]
  PrintingJobWork            PrintingJobWork[]
  OnlineSales                OnlineSales[]
  OnlineSalesReturn          OnlineSalesReturn[]
  CreditDebitNote            CreditDebitNote[]

  ShippingAddress          ShippingAddress[]
  ContactDetails           ContactDetails[]
  Order                    Order[]
  CertificateDetail        CertificateDetail[]
  Sample                   Sample[]
  partyBranch              PartyBranch[]
  DirectReturnOrPoReturn   DirectReturnOrPoReturn[]
  PurchaseCancel           PurchaseCancel[]
  BranchType               BranchType[]
  RawMaterial              RawMaterial[]
  PartyMaterials           PartyMaterials[]
  PartyContactDetails      PartyContactDetails[]
  BranchContactDetails     BranchContactDetails[]
  RequirementPlanningForm  RequirementPlanningForm[]
  PartyAttachments         PartyAttachments[]
  RaiseIndent              RaiseIndent[]
  MaterialIssue            MaterialIssue[]
  RequirementPlanningItems RequirementPlanningItems[]
  AccessoryPoSupplier      AccessoryPo[]              @relation(name: "supplier")
  AccessoryPoDelivery      AccessoryPo[]              @relation(name: "deliveryTo")
  AccesssoryPurchaseCancel AccesssoryPurchaseCancel[]
  AccessoryInward          AccessoryInward[]
  AccessoryReturn          AccessoryReturn[]
  AccessoryBillEntry       AccessoryBillEntry[]
  stocks                   Stock[]
  AccessoryStock           AccessoryStock[]
}

model PartyBranch {
  id                   Int                    @id @default(autoincrement())
  branchName           String?
  branchAliasName      String?
  branchCode           String?
  active               Boolean?               @default(true)
  City                 City?                  @relation(fields: [branchCityId], references: [id])
  branchCityId         Int?
  branchLandMark       String?
  branchAddress        String?                @db.LongText
  branchPincode        String?
  branchEmail          String?                @db.LongText
  branchContactPerson  String?
  branchDesignation    String?
  branchDepartment     String?
  branchContact        String?
  branchWebsite        String?
  branchAccountNumber  String?
  branchBankname       String?
  branchIfscCode       String?
  branchBankBranchName String?
  Party                Party?                 @relation(fields: [partyId], references: [id], onDelete: Cascade)
  partyId              Int?
  isMainBranch         Boolean?               @default(false)
  BranchType           BranchType?            @relation(fields: [branchTypeId], references: [id])
  branchTypeId         Int?
  partyShippingAddress PartyShippingAddress[]
  BranchContactDetails BranchContactDetails[]
  BranchAttchments     BranchAttchments[]
}

model BranchContactDetails {
  id                 Int          @id @default(autoincrement())
  PartyBranch        PartyBranch? @relation(fields: [branchId], references: [id], onDelete: Cascade)
  branchId           Int?
  Party              Party?       @relation(fields: [partyId], references: [id], onDelete: Cascade)
  partyId            Int?
  contactPersonName  String?
  mobileNo           String?
  email              String?
  designation        String?
  department         String?
  alterContactNumber String?
}

model PartyShippingAddress {
  id            Int          @id @default(autoincrement())
  PartyBranch   PartyBranch? @relation(fields: [partyBranchId], references: [id])
  partyBranchId Int?
  address       String?      @db.LongText
  aliasName     String?      @db.LongText
}

model PartyMaterials {
  id           Int      @id @default(autoincrement())
  name         String?
  Party        Party?   @relation(fields: [partyId], references: [id], onDelete: Cascade)
  partyId      Int?
  value        Int?
  isMainBranch Boolean? @default(false)
}

model PartyContactDetails {
  id                 Int     @id @default(autoincrement())
  contactPersonName  String?
  mobileNo           String?
  email              String?
  Designation        String?
  department         String?
  Party              Party?  @relation(fields: [partyId], references: [id], onDelete: Cascade)
  partyId            Int?
  alterContactNumber String?
}

model PartyAttachments {
  id        Int       @id @default(autoincrement())
  Party     Party?    @relation(fields: [partyId], references: [id], onDelete: Cascade)
  partyId   Int?
  filePath  String?
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt
