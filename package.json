{
  "name": "pharma-backend",
  "type": "module",
  "version": "1.0.0",
  "description": "pharma backend",
  "main": "server.js",
  "scripts": {
    "dev:client": "cd client && npm run start",
    "dev:server": "nodemon --max-old-space-size=4096 server.js",
    "migrate": "npx prisma migrate dev --schema ./src/models/schema.prisma",
    "migrate:deploy": "npx prisma migrate deploy --schema ./src/models/schema.prisma",
    "prisma:generate": "npx prisma generate --schema ./src/models/schema.prisma",
    "studio": "npx prisma studio --schema ./src/models/schema.prisma",
    "start": "node --max-old-space-size=4096 server.js",
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "start:prod": "NODE_ENV=production node server.js",
    "server": "NODE_OPTIONS = --max-old-space-size=8192",
    "postinstall": "prisma generate --schema ./src/models/schema.prisma",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@prisma/client": "^4.16.2",
    "axios": "^1.7.9",
    "bcrypt": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "joi": "^17.8.3",
    "jsonwebtoken": "^9.0.0",
    "mathjs": "^14.8.1",
    "moment": "^2.30.1",
    "multer": "^1.4.5-lts.1",
    "mysql": "^2.18.1",
    "nodemailer": "^6.9.1",
    "react-to-print": "^3.2.0",
    "socket.io": "^4.6.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "concurrently": "^9.2.1",
    "nodemon": "^3.0.1",
    "prisma": "^4.16.2",
    "source-map-loader": "^4.0.1"
  }
}